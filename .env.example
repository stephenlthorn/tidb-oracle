APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
AUTO_CREATE_SCHEMA=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tidb_oracle
REDIS_URL=redis://localhost:6379/0

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ENTERPRISE_MODE=false
SECURITY_REQUIRE_PRIVATE_LLM_ENDPOINT=false
SECURITY_ALLOWED_LLM_BASE_URLS=
SECURITY_FAIL_CLOSED_ON_MISSING_LLM_KEY=false
SECURITY_FAIL_CLOSED_ON_MISSING_EMBEDDING_KEY=false
SECURITY_REDACT_BEFORE_LLM=true
SECURITY_REDACT_AUDIT_LOGS=false
SECURITY_TRUSTED_HOST_ALLOWLIST=
SECURITY_ALLOW_INSECURE_HTTP_LLM=false
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_TOP_K=8

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_OAUTH_TOKEN_PATH=.google-drive-token.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
FAKE_DRIVE_INCLUDE_GITHUB=false

CHORUS_API_KEY=
CHORUS_BASE_URL=

EMAIL_MODE=draft
INTERNAL_DOMAIN_ALLOWLIST=pingcap.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=tidb-oracle@pingcap.com

SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=
